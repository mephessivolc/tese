# usuário dentro do container
USERNAME=clovis-caface
USER_UID=1000
USER_GID=1000

# portas locais do host
JUPYTER_PORT=8888
APP_PORT=8080

# limites do container interativo no servidor
WORKSPACE_CPUS=8
WORKSPACE_MEM_LIMIT=32g
WORKSPACE_MEM_RESERVATION=16g
WORKSPACE_PIDS_LIMIT=256
WORKSPACE_SHM_SIZE=2g

# job CPU
SIM_COMMAND=python run_scan.py
SIM_CPU_CPUS=12
SIM_CPU_MEM_LIMIT=64g
SIM_CPU_MEM_RESERVATION=32g
SIM_CPU_PIDS_LIMIT=256
SIM_CPU_SHM_SIZE=4g

# job GPU
GPU_DEVICE_ID=0
SIM_GPU_CPUS=16
SIM_GPU_MEM_LIMIT=128g
SIM_GPU_MEM_RESERVATION=64g
SIM_GPU_PIDS_LIMIT=256
SIM_GPU_SHM_SIZE=8g
